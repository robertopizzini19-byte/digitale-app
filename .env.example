# DigiITAle — Variabili d'ambiente (pubbliche)
# ------------------------------------------------------------------
# Copia questo file in `.env.local` e riempi i valori dal tuo progetto Supabase.
# `.env.local` è ignorato da Git — non verrà mai committato.
#
# NEXT_PUBLIC_* = visibili nel bundle JavaScript del browser (ok, non sono segreti)
# ------------------------------------------------------------------

# URL del tuo progetto Supabase — es. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon public key — Settings → API → "anon" → "public"
# Sicura nel bundle: la sicurezza è garantita da RLS nelle policy SQL.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
