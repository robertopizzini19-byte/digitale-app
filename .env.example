# digITAle — variabili d'ambiente (esempio)
#
# Copia in `.env.local` e compila. `.env.local` è in .gitignore.
# Per produzione: stessi valori in Netlify > Site configuration > Environment variables.
#
# NEXT_PUBLIC_* = visibili nel bundle JavaScript del browser (non sono segreti).
# Le altre (senza prefisso) sono solo server-side.

# --- Supabase (obbligatorio per auth + db) ---
# URL progetto — es. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon public key — Settings > API > "anon / public". Sicurezza garantita da RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Sentry (opzionale — se assente, observability fa graceful fallback a console) ---
# REGION OBBLIGATORIA: eu.sentry.io (GDPR/DPF compliance)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@o0.ingest.eu.sentry.io/0
# SENTRY_ORG=digitale
# SENTRY_PROJECT=digitale-web
# SENTRY_ENVIRONMENT=production
# SENTRY_AUTH_TOKEN=        # solo lato build per sourcemap upload

# --- Stripe (futuro — pagamenti) ---
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...           # server-only, MAI nel bundle
# STRIPE_WEBHOOK_SECRET=whsec_...         # server-only

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
